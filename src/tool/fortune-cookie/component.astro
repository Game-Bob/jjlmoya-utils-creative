---
import { Icon } from 'astro-icon/components';
import type { FortuneCookieUI } from './index';

interface Props {
  ui: FortuneCookieUI;
}

const { ui } = Astro.props;

const ASSETS = {
  whole: '/images/utilities/fortune/fc-whole.webp',
  cracked1: '/images/utilities/fortune/fc-crack-1.webp',
  cracked2: '/images/utilities/fortune/fc-crack-2.webp',
  left: '/images/utilities/fortune/fc-left.webp',
  right: '/images/utilities/fortune/fc-right.webp',
  paper: '/images/utilities/fortune/fc-paper.webp',
  crumbs: '/images/utilities/fortune/fc-crumbs.webp',
};
---

<div id="fortune-cookie-root" class="fortune-cookie" data-ui={JSON.stringify(ui)}>
  <div class="fortune-cookie-root">
    <div class="fortune-cookie-card">
      <div class="fortune-cookie-glow"></div>

      <div class="fortune-cookie-content">
        <h2 id="fortune-instruction" class="fortune-cookie-instruction">
          {ui.instruction}
        </h2>

        <div id="fortune-cookie-stage" class="fortune-cookie-stage">
          <div id="fortune-cookie-body" class="fortune-cookie-body">
            <img
              src={ASSETS.whole}
              alt="Fortune Cookie"
              class="fortune-cookie-img"
              id="fortune-cookie-img"
              loading="eager"
            />
          </div>

          <div id="fortune-cookie-broken" class="fortune-cookie-broken hidden">
            <img
              src={ASSETS.left}
              class="fortune-cookie-half fortune-cookie-half-left"
              id="fortune-half-left"
              loading="eager"
            />
            <img
              src={ASSETS.right}
              class="fortune-cookie-half fortune-cookie-half-right"
              id="fortune-half-right"
              loading="eager"
            />
          </div>

          <div id="fortune-paper" class="fortune-cookie-paper">
            <img src={ASSETS.paper} class="fortune-cookie-paper-img" />

            <div class="fortune-cookie-paper-content">
              <p id="fortune-text" class="fortune-cookie-text">
                "..."
              </p>
              <div id="fortune-lucky-numbers" class="fortune-cookie-lucky-numbers"></div>
            </div>
          </div>

          <div id="fortune-particles" class="fortune-cookie-particles"></div>
        </div>

        <div id="fortune-reset-ui" class="fortune-cookie-reset">
          <p class="fortune-cookie-status">{ui.dailyStatus}</p>
          <button id="fortune-share-btn" class="fortune-cookie-share-btn">
            <Icon name="mdi:share-variant" /> {ui.shareBtn}
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import type { FortuneCookieUI } from './index';

  const root = document.getElementById('fortune-cookie-root') as HTMLElement;
  const ui = JSON.parse(root.dataset.ui || '{}') as FortuneCookieUI;

  const fortunes = JSON.parse(ui.fortunes || '[]') as string[];

  function getLuckyNumbers() {
    const nums = new Set<number>();
    while (nums.size < 6) {
      nums.add(Math.floor(Math.random() * 49) + 1);
    }
    return Array.from(nums).sort((a, b) => a - b);
  }

  class FortuneCookie {
    private health = 3;
    private isBroken = false;
    private el = {
      stage: document.getElementById('fortune-cookie-stage')!,
      body: document.getElementById('fortune-cookie-body')!,
      img: document.getElementById('fortune-cookie-img') as HTMLImageElement,
      broken: document.getElementById('fortune-cookie-broken')!,
      halfLeft: document.getElementById('fortune-half-left') as HTMLElement,
      halfRight: document.getElementById('fortune-half-right') as HTMLElement,
      paper: document.getElementById('fortune-paper')!,
      text: document.getElementById('fortune-text')!,
      numbers: document.getElementById('fortune-lucky-numbers')!,
      instruction: document.getElementById('fortune-instruction')!,
      particles: document.getElementById('fortune-particles')!,
      resetUi: document.getElementById('fortune-reset-ui')!,
      shareBtn: document.getElementById('fortune-share-btn') as HTMLButtonElement,
    };

    private assets = {
      cracked1: '/images/utilities/fortune/fc-crack-1.webp',
      cracked2: '/images/utilities/fortune/fc-crack-2.webp',
    };

    constructor() {
      this.checkDaily();
      this.el.stage.addEventListener('click', () => this.tap());
      this.el.shareBtn?.addEventListener('click', () => this.shareFortune());
    }

    private async shareFortune() {
      const text = this.el.text.innerText;
      const nums = this.el.numbers.innerText.replace(/\n/g, ' ');

      const shareTextCompiled = (ui.shareText || '')
        .replace('$TEXT', text)
        .replace('$NUMS', nums);

      const shareData = {
        title: ui.shareTitle || '',
        text: shareTextCompiled,
        url: window.location.href,
      };

      try {
        if (navigator.share) {
          await navigator.share(shareData);
        } else {
          await navigator.clipboard.writeText(`${shareData.text} ${shareData.url}`);
          const originalText = this.el.shareBtn.innerHTML;
          this.el.shareBtn.innerHTML = `<span>${ui.copied || ''}</span>`;
          setTimeout(() => {
            this.el.shareBtn.innerHTML = originalText;
          }, 2000);
        }
      } catch (err) {
        console.error('Error sharing:', err);
      }
    }

    private checkDaily() {
      const today = new Date().toISOString().split('T')[0];
      const storedData = localStorage.getItem('jjlmoya-creative-fortune');

      if (storedData) {
        try {
          const data = JSON.parse(storedData);
          if (data.date === today) {
            this.setupFortuneContent(data.msgIndex, data.nums);
            this.instantOpen();
          }
        } catch {
          localStorage.removeItem('jjlmoya-creative-fortune');
        }
      }
    }

    private prepareNewFortune(today: string) {
      const index = Math.floor(Math.random() * fortunes.length);
      const nums = getLuckyNumbers();

      const fortuneData = {
        date: today,
        msgIndex: index,
        nums: nums,
      };
      localStorage.setItem('jjlmoya-creative-fortune', JSON.stringify(fortuneData));

      this.setupFortuneContent(index, nums);
    }

    private setupFortuneContent(index: number, nums: number[]) {
      this.el.text.innerText = fortunes[index] || '';
      this.el.numbers.innerHTML = nums
        .map(
          (n) =>
            `<span class="fortune-cookie-number">${n}</span>`
        )
        .join('');
    }

    private tap() {
      if (this.isBroken) return;

      this.health--;
      this.spawnCrumbs(5);

      this.el.body.classList.remove('fortune-cookie-shake-1', 'fortune-cookie-shake-2', 'fortune-cookie-shake-3');
      void this.el.body.offsetWidth;
      this.el.body.classList.add(`fortune-cookie-shake-${4 - this.health}`);

      if (this.health === 2) {
        this.el.img.src = this.assets.cracked1;
      } else if (this.health === 1) {
        this.el.img.src = this.assets.cracked2;
      } else if (this.health <= 0) {
        this.breakOpen();
      }
    }

    private breakOpen() {
      this.isBroken = true;

      const today = new Date().toISOString().split('T')[0] as string;
      this.prepareNewFortune(today);

      this.el.instruction.innerText = ui.title || '';

      this.el.broken.classList.remove('hidden');
      this.el.body.classList.add('hidden');

      void this.el.broken.offsetWidth;

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          this.el.halfLeft.style.transform = 'translate(-120px, 60px) rotate(-45deg)';
          this.el.halfLeft.style.opacity = '0';
          this.el.halfRight.style.transform = 'translate(120px, 60px) rotate(45deg)';
          this.el.halfRight.style.opacity = '0';
        });
      });

      setTimeout(() => {
        this.el.paper.classList.add('visible');
      }, 100);

      this.spawnCrumbs(20);

      setTimeout(() => {
        this.el.resetUi.classList.add('visible');
      }, 1000);
    }

    private instantOpen() {
      this.isBroken = true;
      this.el.instruction.innerText = ui.title || '';
      this.el.body.classList.add('hidden');
      this.el.paper.classList.add('visible');
      this.el.resetUi.classList.add('visible');
    }

    private spawnCrumbs(amount: number) {
      for (let i = 0; i < amount; i++) {
        const crumb = document.createElement('div');
        crumb.classList.add('fortune-cookie-crumb');

        const size = Math.random() * 4 + 2;
        crumb.style.width = `${size}px`;
        crumb.style.height = `${size}px`;
        crumb.style.left = '50%';
        crumb.style.top = '50%';

        const angle = Math.random() * Math.PI * 2;
        const velocity = Math.random() * 50 + 20;
        const tx = Math.cos(angle) * velocity;
        const ty = Math.sin(angle) * velocity;

        this.el.particles.appendChild(crumb);

        const anim = crumb.animate(
          [
            { transform: 'translate(-50%, -50%) scale(1)', opacity: 1 },
            {
              transform: `translate(calc(-50% + ${tx}px), calc(-50% + ${ty + 50}px)) scale(0)`,
              opacity: 0,
            },
          ],
          {
            duration: 600 + Math.random() * 400,
            easing: 'cubic-bezier(0,0,0.2,1)',
          }
        );

        anim.onfinish = () => crumb.remove();
      }
    }
  }

  new FortuneCookie();
</script>

<style>
.fortune-cookie {
  --fortune-cookie-bg: #fff;
  --fortune-cookie-bg-muted: #fffbeb;
  --fortune-cookie-text: #0f172a;
  --fortune-cookie-text-muted: #475569;
  --fortune-cookie-text-dim: #64748b;
  --fortune-cookie-border: #fef3c7;
  --fortune-cookie-shadow: rgba(0, 0, 0, 0.05);
  --fortune-cookie-primary: #f59e0b;
  --fortune-cookie-primary-on: #fff;
  --fortune-cookie-accent: #fcd34d;
  --fortune-cookie-success: #10b981;
  --fortune-cookie-warning: #f59e0b;
  --fortune-cookie-error: #f43f5e;
}

:global(.theme-dark) .fortune-cookie {
  --fortune-cookie-bg: #0f172a;
  --fortune-cookie-bg-muted: #1e293b;
  --fortune-cookie-text: #f8fafc;
  --fortune-cookie-text-muted: #94a3b8;
  --fortune-cookie-text-dim: #64748b;
  --fortune-cookie-border: #334155;
  --fortune-cookie-shadow: rgba(0, 0, 0, 0.3);
  --fortune-cookie-primary: #fbbf24;
  --fortune-cookie-primary-on: #fff;
  --fortune-cookie-accent: #fcd34d;
  --fortune-cookie-success: #34d399;
  --fortune-cookie-warning: #fbbf24;
  --fortune-cookie-error: #fb7185;
}

.fortune-cookie-root {
  width: 100%;
  max-width: 64rem;
  margin-left: auto;
  margin-right: auto;
}

.fortune-cookie-card {
  position: relative;
  background-color: var(--fortune-cookie-bg);
  border-radius: 1.5rem;
  box-shadow: 0 25px 50px -12px var(--fortune-cookie-shadow);
  overflow: hidden;
  border: 1px solid var(--fortune-cookie-border);
  min-height: 600px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 2rem;
}

.fortune-cookie-glow {
  position: absolute;
  inset: 0;
  opacity: 0.1;
  pointer-events: none;
  background-image: radial-gradient(circle at center, var(--fortune-cookie-primary), transparent, transparent);
}

.fortune-cookie-content {
  position: relative;
  z-index: 10;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.fortune-cookie-instruction {
  font-size: 1.25rem;
  line-height: 1.75rem;
  font-weight: 700;
  color: #92400e;
  margin-bottom: 2rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  animation: fortune-cookie-pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

:global(.theme-dark) .fortune-cookie-instruction {
  color: #fbbf24;
}

@keyframes fortune-cookie-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: .5; }
}

.fortune-cookie-stage {
  position: relative;
  width: 20rem;
  height: 20rem;
  cursor: pointer;
}

@media (min-width: 768px) {
  .fortune-cookie-stage {
    width: 24rem;
    height: 24rem;
  }
}

.fortune-cookie-body {
  position: absolute;
  inset: 2rem;
  transition-property: transform;
  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  transition-duration: 100ms;
}

@media (min-width: 768px) {
  .fortune-cookie-body {
    inset: 3rem;
  }
}

.fortune-cookie-body:active {
  transform: scale(0.95);
}

.fortune-cookie-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  z-index: 10;
  position: relative;
}

.fortune-cookie-broken {
  position: absolute;
  inset: 2rem;
  pointer-events: none;
}

.fortune-cookie-broken.hidden {
  display: none;
}

@media (min-width: 768px) {
  .fortune-cookie-broken {
    inset: 3rem;
  }
}

.fortune-cookie-half {
  position: absolute;
  width: 50%;
  height: 100%;
  object-fit: contain;
  transition-property: all;
  transition-timing-function: cubic-bezier(0, 0, 0.2, 1);
  transition-duration: 1000ms;
}

.fortune-cookie-half-left {
  left: 0;
  transform-origin: bottom left;
}

.fortune-cookie-half-right {
  right: 0;
  transform-origin: bottom right;
}

.fortune-cookie-paper {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.5);
  width: 85%;
  max-width: 320px;
  background-color: #fff;
  border-radius: 2px;
  box-shadow: 
    0 10px 15px -3px rgba(0, 0, 0, 0.2),
    0 4px 6px -2px rgba(0, 0, 0, 0.1),
    inset 0 0 20px rgba(0, 0, 0, 0.05);
  opacity: 0;
  transition-property: all;
  transition-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);
  transition-duration: 800ms;
  z-index: 0;
  overflow: hidden;
}

.fortune-cookie-paper.visible {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1) rotate(-1deg);
  z-index: 20;
}

.fortune-cookie-paper-img {
  width: 100%;
  height: auto;
  display: block;
  opacity: 0.15;
  pointer-events: none;
  mix-blend-mode: multiply;
}

.fortune-cookie-paper-content {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 1.5rem;
  text-align: center;
  z-index: 10;
}

.fortune-cookie-text {
  color: #1e293b;
  font-weight: 800;
  font-size: 1.125rem;
  line-height: 1.4;
  transform: rotate(-1deg);
  user-select: text;
  margin: 0;
}

@media (min-width: 768px) {
  .fortune-cookie-text {
    font-size: 1.25rem;
  }
}

.fortune-cookie-lucky-numbers {
  margin-top: 1rem;
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  justify-content: center;
  transform: rotate(-1deg);
}

:global(.fortune-cookie-number) {
  font-size: 0.75rem;
  line-height: 1rem;
  font-weight: 700;
  background-color: #f1f5f9;
  color: #dc2626;
  padding-left: 0.5rem;
  padding-right: 0.5rem;
  padding-top: 0.125rem;
  padding-bottom: 0.125rem;
  border-radius: 0.25rem;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  border: 1px solid #fee2e2;
}

.fortune-cookie-particles {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: visible;
  z-index: 20;
}

.fortune-cookie-reset {
  display: none;
  margin-top: 3rem;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
}

.fortune-cookie-reset.visible {
  display: flex;
}

.fortune-cookie-status {
  font-size: 0.875rem;
  line-height: 1.25rem;
  color: var(--fortune-cookie-text-dim);
}

.fortune-cookie-share-btn {
  padding-left: 1.5rem;
  padding-right: 1.5rem;
  padding-top: 0.5rem;
  padding-bottom: 0.5rem;
  background-color: #f1f5f9;
  color: #334155;
  border-radius: 9999px;
  font-size: 0.875rem;
  line-height: 1.25rem;
  font-weight: 700;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  transition-property: color, background-color, border-color, text-decoration-color, fill, stroke;
  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  transition-duration: 150ms;
}

:global(.theme-dark) .fortune-cookie-share-btn {
  background-color: #1e293b;
  color: #cbd5e1;
}

.fortune-cookie-share-btn:hover {
  background-color: #e2e8f0;
}

:global(.theme-dark) .fortune-cookie-share-btn:hover {
  background-color: #334155;
}

.fortune-cookie-shake-1 {
  animation: fortune-cookie-shake 0.3s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
}

.fortune-cookie-shake-2 {
  animation: fortune-cookie-shake 0.4s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
}

.fortune-cookie-shake-3 {
  animation: fortune-cookie-shake 0.5s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
}

@keyframes fortune-cookie-shake {
  10%, 90% { transform: translate3d(-1px, 0, 0) rotate(-1deg); }
  20%, 80% { transform: translate3d(2px, 0, 0) rotate(2deg); }
  30%, 50%, 70% { transform: translate3d(-4px, 0, 0) rotate(-4deg); }
  40%, 60% { transform: translate3d(4px, 0, 0) rotate(4deg); }
}

:global(.fortune-cookie-crumb) {
  position: absolute;
  width: 20px;
  height: 20px;
  background-image: url("/images/utilities/fortune/fc-crumbs.webp");
  background-size: contain;
  background-repeat: no-repeat;
  pointer-events: none;
}
</style>
