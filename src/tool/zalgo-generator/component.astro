---
import { Icon } from 'astro-icon/components';
import './style.css';
import type { ZalgoGeneratorUI } from './index';

interface Props {
  ui: ZalgoGeneratorUI;
}

const { ui } = Astro.props;
---

<div id="zalgo-generator-root" class="zalgo-generator" data-ui={JSON.stringify(ui)}>
  <div class="zalgo-generator-shell">
    <div class="zalgo-generator-card">
      <p class="zalgo-generator-description">{ui.description}</p>

      <div class="zalgo-generator-group">
        <label class="zalgo-generator-label" for="zalgo-input">
          {ui.inputPlaceholder}
        </label>
        <textarea
          id="zalgo-input"
          class="zalgo-generator-input"
          placeholder={ui.inputPlaceholder}
        ></textarea>
      </div>

      <div class="zalgo-generator-group">
        <label class="zalgo-generator-label" for="zalgo-intensity">
          {ui.intensityLabel}
        </label>
        <input
          type="range"
          id="zalgo-intensity"
          class="zalgo-generator-intensity"
          min="1"
          max="50"
          value="10"
        />
      </div>

      <div class="zalgo-generator-group">
        <span class="zalgo-generator-label">{ui.outputLabel}</span>
        <div id="zalgo-output" class="zalgo-generator-output"></div>
      </div>

      <button id="zalgo-copy-btn" class="zalgo-generator-copy-btn">
        <Icon name="mdi:content-copy" />
        {ui.copyBtn}
      </button>
    </div>
  </div>
</div>

<script>
  const root = document.getElementById('zalgo-generator-root') as HTMLElement;
  const ui = JSON.parse(root.dataset.ui as string) as Record<string, string>;

  const input = document.getElementById('zalgo-input') as HTMLTextAreaElement;
  const output = document.getElementById('zalgo-output') as HTMLElement;
  const intensity = document.getElementById('zalgo-intensity') as HTMLInputElement;
  const copyBtn = document.getElementById('zalgo-copy-btn') as HTMLButtonElement;

  const zalgoChars = {
    up: [
      '\u030d', '\u030e', '\u0304', '\u0305', '\u033f', '\u0311', '\u0306', '\u0310',
      '\u0352', '\u0357', '\u0351', '\u0307', '\u0308', '\u030a', '\u0342', '\u0343',
      '\u0344', '\u034a', '\u034b', '\u034c', '\u0303', '\u0302', '\u030c', '\u0350',
      '\u0300', '\u0301', '\u030b', '\u030f', '\u0312', '\u0313', '\u0314', '\u033d',
      '\u0309', '\u0363', '\u0364', '\u0365', '\u0366', '\u0367', '\u0368', '\u0369',
      '\u036a', '\u036b', '\u036c', '\u036d', '\u036e', '\u036f', '\u033e', '\u035b',
      '\u0346', '\u031a'
    ],
    mid: [
      '\u0315', '\u031b', '\u0340', '\u0341', '\u0358', '\u0321', '\u0322', '\u0327',
      '\u0328', '\u0334', '\u0335', '\u0336', '\u034f', '\u035c', '\u035d', '\u035e',
      '\u035f', '\u0360', '\u0362', '\u0338', '\u0337', '\u0361', '\u0489'
    ],
    down: [
      '\u0316', '\u0317', '\u0318', '\u0319', '\u031c', '\u031d', '\u031e', '\u031f',
      '\u0320', '\u0324', '\u0325', '\u0326', '\u0329', '\u032a', '\u032b', '\u032c',
      '\u032d', '\u032e', '\u032f', '\u0330', '\u0331', '\u0332', '\u0333', '\u0339',
      '\u033a', '\u033b', '\u033c', '\u0345', '\u0347', '\u0348', '\u0349', '\u034d',
      '\u034e', '\u0353', '\u0354', '\u0355', '\u0356', '\u0359', '\u035a', '\u0323'
    ]
  };

  function rand(max: number) {
    return Math.floor(Math.random() * max);
  }

  function generateZalgo(text: string, level: number) {
    let result = '';
    for (let i = 0; i < text.length; i++) {
      const char = text[i];
      if (zalgoChars.up.includes(char) || zalgoChars.mid.includes(char) || zalgoChars.down.includes(char)) {
        continue;
      }
      result += char;

      for (let j = 0; j < level; j++) {
        result += zalgoChars.up[rand(zalgoChars.up.length)];
        result += zalgoChars.mid[rand(zalgoChars.mid.length)];
        result += zalgoChars.down[rand(zalgoChars.down.length)];
      }
    }
    return result;
  }

  function update() {
    const text = input.value;
    const level = parseInt(intensity.value) / 5;
    output.textContent = text ? generateZalgo(text, level) : '';
  }

  input.addEventListener('input', update);
  intensity.addEventListener('input', update);

  copyBtn.addEventListener('click', () => {
    const text = output.textContent;
    if (!text) return;
    navigator.clipboard.writeText(text);
    const original = copyBtn.innerHTML;
    copyBtn.innerHTML = `<span>${ui.copied}</span>`;
    setTimeout(() => {
      copyBtn.innerHTML = original;
    }, 2000);
  });

  update();
</script>
